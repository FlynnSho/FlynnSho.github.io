function loadData(){ try { return JSON.parse(localStorage.getItem('fs_fitness')||'{}'); } catch(e){ return {}; } }
function saveData(d){ localStorage.setItem('fs_fitness', JSON.stringify(d)); }
let DB = loadData();

function todayStr(){ const n=new Date(); return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,'0')}-${String(n.getDate()).padStart(2,'0')}`; }
function dateStr(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
function parseDate(s){ return new Date(s+'T12:00:00'); }
function dayOfWeek(s){ const d=parseDate(s).getDay(); return d===0?6:d-1; }
function getWeekStart(s){ const dt=parseDate(s), dow=dt.getDay()===0?6:dt.getDay()-1; dt.setDate(dt.getDate()-dow); return dateStr(dt); }
function addDays(s,n){ const d=parseDate(s); d.setDate(d.getDate()+n); return dateStr(d); }
function formatDate(s){ return parseDate(s).toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short'}); }

function getScheduledWorkoutForDate(ds){
  const dow=dayOfWeek(ds);
  if(!WEEK_SCHEDULE.includes(dow)) return null;
  const slotInWeek=WEEK_SCHEDULE.indexOf(dow);
  const epochStart=parseDate('2026-06-01');
  const weeksSince=Math.floor((parseDate(ds)-epochStart)/(7*86400000));
  const totalSlot=weeksSince*4+slotInWeek;
  return WORKOUTS[((totalSlot%4)+4)%4];
}
function getWorkoutForDate(d){
  const s=(DB.sessions||{})[d];
  if(s?.workoutId) return WORKOUTS.find(w=>w.id===s.workoutId)||null;
  return getScheduledWorkoutForDate(d);
}

let activeDate=null, activeWorkout=null, setStates=[], openRepSet=null;

function showTab(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{ if(t.getAttribute('onclick')===`showTab('${id}')`) t.classList.add('active'); });
  if(id==='calendar') renderCalendar();
  if(id==='stats') renderStats();
}

function renderPlan(){
  const today=todayStr(), weekStart=getWeekStart(today);
  document.getElementById('week-label').innerHTML=`Week of ${formatDate(weekStart)}`;
  const dayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  let html='';
  for(let i=0;i<7;i++){
    const d=addDays(weekStart,i), dow=dayOfWeek(d), isToday=d===today;
    const workout=getWorkoutForDate(d), session=(DB.sessions||{})[d], isDone=session?.completedAt;
    if(workout){
      html+=`<div class="day-row${isDone?' done':''}" id="dayrow-${d}">
        <div class="day-row-left">
          <div class="day-row-num">${dayNames[dow]}${isToday?' · Today':''}</div>
          <div class="day-row-name">${workout.name}</div>
          <div class="day-row-sub">${workout.focus}</div>
        </div>
        <div class="day-row-right">
          ${isDone?'<div class="day-done-badge">✓ Done</div>':`<button class="start-btn" onclick="startWorkout('${d}')">${isToday?'Start':'View'}</button>`}
        </div>
      </div>`;
    } else {
      html+=`<div class="rest-row"><div class="rest-label">${dayNames[dow]}${isToday?' · Today':''} &nbsp;Rest day</div></div>`;
    }
  }
  document.getElementById('day-list').innerHTML=html;
  const sessions=DB.sessions||{};
  const totalDone=Object.values(sessions).filter(s=>s.completedAt).length;
  const weekDates=Array.from({length:7},(_,i)=>addDays(weekStart,i));
  const weekDone=weekDates.filter(d=>sessions[d]?.completedAt).length;
  document.getElementById('hero-sessions').innerHTML=`${totalDone}<span class="hero-stat-u">total</span>`;
  document.getElementById('hero-week').innerHTML=`${weekDone}<span class="hero-stat-u">/ 4</span>`;
}

function startWorkout(date){
  activeDate=date; activeWorkout=getWorkoutForDate(date);
  if(!activeWorkout) return;
  DB.sessions=DB.sessions||{};
  if(!DB.sessions[date]){
    DB.sessions[date]={ workoutId:activeWorkout.id, sets:activeWorkout.exercises.map(ex=>Array.from({length:ex.sets},()=>({done:false,reps:0}))), completedAt:null };
    saveData(DB);
  }
  setStates=DB.sessions[date].sets.map(exSets=>exSets.map(s=>({...s})));
  openRepSet=null;
  document.getElementById('wo-title').textContent=activeWorkout.name;
  renderWorkout();
  document.getElementById('workout-overlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeWorkout(){
  document.getElementById('workout-overlay').classList.remove('open');
  document.body.style.overflow='';
  activeDate=null; activeWorkout=null; openRepSet=null;
  renderPlan();
}

function completeWorkout(){
  if(!activeDate||!activeWorkout) return;
  DB.sessions[activeDate].completedAt=new Date().toISOString();
  saveData(DB); closeWorkout();
}

function renderWorkout(){
  if(!activeWorkout) return;
  const totalSets=setStates.reduce((s,ex)=>s+ex.length,0);
  const doneSets=setStates.reduce((s,ex)=>s+ex.filter(set=>set.done).length,0);
  document.getElementById('wo-progress').style.width=(totalSets?Math.round(doneSets/totalSets*100):0)+'%';
  const allDone=doneSets===totalSets;
  const btn=document.getElementById('wo-complete-btn');
  btn.disabled=!allDone;
  btn.textContent=allDone?`✓ Complete workout (${doneSets}/${totalSets} sets)`:`Complete workout — ${doneSets}/${totalSets} sets done`;
  let html='';
  activeWorkout.exercises.forEach((ex,ei)=>{
    const exSets=setStates[ei], exDone=exSets.every(s=>s.done);
    html+=`<div class="ex-card${exDone?' completed':''}">
      <div class="ex-illustration">${getIllustration(ex.name)}</div>
      <div class="ex-card-header">
        <div class="ex-name">${ex.name}</div>
        <div class="ex-info">${exDone?'✓ Done':ex.weight}</div>
      </div>
      ${(()=>{ const d=EX_DATA[ex.name]; if(!d) return ''; return `<div class="ex-muscles">${d.muscles.map(m=>`<span class="muscle-tag">${m}</span>`).join('')}</div><p class="ex-cues">${d.cues}</p>`; })()}
      <div class="sets-row">`;
    exSets.forEach((s,si)=>{
      html+=`<div class="set-btn${s.done?' set-done':''}" onclick="openRepCounter(${ei},${si})">
        <span class="set-num">SET ${si+1}</span>
        <span class="set-count">${s.done?s.reps:ex.reps.split('–')[0]}</span>
      </div>`;
    });
    html+=`</div>`;
    if(openRepSet&&openRepSet.exIdx===ei){
      const si=openRepSet.setIdx, cur=setStates[ei][si].reps||(parseInt(ex.reps)||10);
      html+=`<div class="rep-counter open">
        <div class="rep-counter-label">// Set ${si+1} — log your reps</div>
        <div class="rep-counter-controls">
          <button class="rep-btn" onclick="adjustReps(${ei},${si},-1)">−</button>
          <div class="rep-display" id="rep-disp-${ei}-${si}">${cur}</div>
          <button class="rep-btn" onclick="adjustReps(${ei},${si},1)">+</button>
        </div>
        <button class="rep-confirm" id="rep-confirm-${ei}-${si}" onclick="confirmSet(${ei},${si})">Log ${cur} rep${cur!==1?'s':''} &nbsp;→</button>
      </div>`;
    }
    const doneSetsEx=exSets.filter(s=>s.done);
    if(doneSetsEx.length){
      html+=`<div class="ex-sets-summary">`;
      exSets.forEach((s,si)=>{ html+=`<span class="set-summary-chip${s.done?' done':''}">S${si+1}${s.done?' · '+s.reps+'r':''}</span>`; });
      html+=`</div>`;
    }
    html+=`</div>`;
  });
  document.getElementById('wo-ex-list').innerHTML=html;
}

function openRepCounter(exIdx,setIdx){
  if(openRepSet&&openRepSet.exIdx===exIdx&&openRepSet.setIdx===setIdx){ openRepSet=null; }
  else { if(!setStates[exIdx][setIdx].reps){ setStates[exIdx][setIdx].reps=parseInt(activeWorkout.exercises[exIdx].reps)||10; } openRepSet={exIdx,setIdx}; }
  renderWorkout();
}

function adjustReps(exIdx,setIdx,delta){
  setStates[exIdx][setIdx].reps=Math.max(0,(setStates[exIdx][setIdx].reps||0)+delta);
  const val=setStates[exIdx][setIdx].reps;
  const el=document.getElementById(`rep-disp-${exIdx}-${setIdx}`);
  if(el) el.textContent=val;
  const btn=document.getElementById(`rep-confirm-${exIdx}-${setIdx}`);
  if(btn) btn.textContent=`Log ${val} rep${val!==1?'s':''} \u00a0→`;
}

function confirmSet(exIdx,setIdx){
  setStates[exIdx][setIdx].done=true;
  if(!setStates[exIdx][setIdx].reps) setStates[exIdx][setIdx].reps=parseInt(activeWorkout.exercises[exIdx].reps)||10;
  openRepSet=null;
  DB.sessions[activeDate].sets=setStates.map(ex=>ex.map(s=>({...s})));
  saveData(DB); renderWorkout();
}

let calYear=new Date().getFullYear(), calMonth=new Date().getMonth();
function renderCalendar(){
  const dayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-grid-head').innerHTML=dayNames.map(d=>`<div class="cal-day-head">${d}</div>`).join('');
  document.getElementById('cal-month-label').textContent=`${months[calMonth]} ${calYear}`;
  const firstDay=new Date(calYear,calMonth,1), lastDay=new Date(calYear,calMonth+1,0);
  const startDow=firstDay.getDay()===0?6:firstDay.getDay()-1;
  const today=todayStr(), sessions=DB.sessions||{};
  let html='';
  for(let i=0;i<startDow;i++){ const d=new Date(calYear,calMonth,1-startDow+i); html+=`<div class="cal-cell other-month">${d.getDate()}</div>`; }
  for(let day=1;day<=lastDay.getDate();day++){
    const d=dateStr(new Date(calYear,calMonth,day)), isToday=d===today;
    const session=sessions[d], workout=getWorkoutForDate(d);
    const isCompleted=session?.completedAt, isScheduled=workout&&!isCompleted&&d>=today, isPast=workout&&!isCompleted&&d<today;
    const dot=isCompleted?`<div class="cal-dot completed"></div>`:isScheduled?`<div class="cal-dot scheduled"></div>`:isPast?`<div class="cal-dot"></div>`:'';
    html+=`<div class="cal-cell${isToday?' today':''}${workout?' has-workout':''}" title="${workout?workout.name:'Rest day'}">${day}${dot}</div>`;
  }
  const trailing=(7-(startDow+lastDay.getDate())%7)%7;
  for(let i=1;i<=trailing;i++) html+=`<div class="cal-cell other-month">${i}</div>`;
  document.getElementById('cal-grid').innerHTML=html;
}
function calPrev(){ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }
function calNext(){ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); }

function getBodyWeight(){ return DB.weight || 62; }

function adjustBodyWeight(delta){
  DB.weight = Math.round((Math.max(30, Math.min(250, getBodyWeight() + delta))) * 10) / 10;
  saveData(DB);
  renderBodyWeight();
}

function renderBodyWeight(){
  const w = getBodyWeight();
  const heroEl = document.getElementById('hero-weight-val');
  if(heroEl) heroEl.textContent = w;
  const statEl = document.getElementById('wt-current-val');
  if(statEl) statEl.textContent = w;
}

function logWeight(){
  if(!DB.weightLog) DB.weightLog = [];
  const today = todayStr();
  DB.weightLog = DB.weightLog.filter(e=>e.date!==today);
  DB.weightLog.push({date:today, weight:getBodyWeight()});
  DB.weightLog.sort((a,b)=>b.date.localeCompare(a.date));
  saveData(DB);
  renderWeightTracker();
}

function buildWeightChart(){
  const log = [...(DB.weightLog||[])].sort((a,b)=>a.date.localeCompare(b.date)).slice(-20);
  if(log.length < 2) return `<div class="wt-empty">Log at least 2 entries to see your chart</div>`;
  const W=400, H=110, ml=38, mr=14, mt=12, mb=22;
  const pw=W-ml-mr, ph=H-mt-mb;
  const weights=log.map(e=>e.weight);
  const minW=Math.min(...weights), maxW=Math.max(...weights);
  const span=Math.max(maxW-minW, 1.5);
  const yMin=minW-span*0.25, yMax=maxW+span*0.25;
  const xFor=i=>ml+(i/(log.length-1))*pw;
  const yFor=w=>mt+ph-((w-yMin)/(yMax-yMin))*ph;
  const pathD=log.map((e,i)=>`${i===0?'M':'L'}${xFor(i).toFixed(1)},${yFor(e.weight).toFixed(1)}`).join(' ');
  // gradient fill under line
  const fillD=pathD+` L${xFor(log.length-1).toFixed(1)},${(mt+ph).toFixed(1)} L${xFor(0).toFixed(1)},${(mt+ph).toFixed(1)} Z`;
  // y axis labels (3 levels)
  const yTicks=[yMin,yMin+(yMax-yMin)*0.5,yMax].map(v=>parseFloat(v.toFixed(1)));
  let svg=`<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;
  svg+=`<defs><linearGradient id="wg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#5b9eff" stop-opacity="0.18"/><stop offset="100%" stop-color="#5b9eff" stop-opacity="0"/></linearGradient></defs>`;
  // grid lines
  yTicks.forEach(yt=>{
    const yp=yFor(yt);
    svg+=`<line x1="${ml}" y1="${yp.toFixed(1)}" x2="${W-mr}" y2="${yp.toFixed(1)}" stroke="#2e2e2e" stroke-width="1"/>`;
    svg+=`<text x="${ml-4}" y="${(yp+3.5).toFixed(1)}" text-anchor="end" fill="#555" font-size="8" font-family="monospace">${yt}</text>`;
  });
  // fill
  svg+=`<path d="${fillD}" fill="url(#wg)"/>`;
  // line
  svg+=`<path d="${pathD}" fill="none" stroke="#5b9eff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`;
  // dots
  log.forEach((e,i)=>{
    const x=xFor(i).toFixed(1), y=yFor(e.weight).toFixed(1), isLast=i===log.length-1;
    svg+=`<circle cx="${x}" cy="${y}" r="${isLast?5:3}" fill="${isLast?'#5b9eff':'#1f1f1f'}" stroke="#5b9eff" stroke-width="${isLast?0:1.5}"/>`;
    if(isLast){
      const tx=parseFloat(x), lw=`${e.weight}kg`, textX=tx+mr>W-50?tx-8:tx+8, anchor=tx+mr>W-50?'end':'start';
      svg+=`<text x="${textX}" y="${(parseFloat(y)-8).toFixed(1)}" text-anchor="${anchor}" fill="#5b9eff" font-size="9" font-family="monospace" font-weight="bold">${lw}</text>`;
    }
  });
  // x axis date labels (first and last)
  svg+=`<text x="${xFor(0).toFixed(1)}" y="${H-4}" text-anchor="start" fill="#444" font-size="8" font-family="monospace">${formatDate(log[0].date)}</text>`;
  if(log.length>1) svg+=`<text x="${xFor(log.length-1).toFixed(1)}" y="${H-4}" text-anchor="end" fill="#444" font-size="8" font-family="monospace">${formatDate(log[log.length-1].date)}</text>`;
  svg+=`</svg>`;
  return `<div class="wt-chart">${svg}</div>`;
}

function renderWeightTracker(){
  renderBodyWeight();
  const chartEl=document.getElementById('wt-chart-area');
  const logEl=document.getElementById('wt-log-area');
  if(!chartEl||!logEl) return;
  chartEl.innerHTML=buildWeightChart();
  const log=[...(DB.weightLog||[])].sort((a,b)=>b.date.localeCompare(a.date));
  if(!log.length){ logEl.innerHTML=''; return; }
  let html=`<div class="wt-log">`;
  log.slice(0,12).forEach(e=>{
    html+=`<div class="wt-log-item"><div class="wt-log-date">${formatDate(e.date)}</div><div class="wt-log-wt">${e.weight}<span class="wt-log-u">kg</span></div></div>`;
  });
  html+=`</div>`;
  logEl.innerHTML=html;
}

function renderStats(){
  const sessions=DB.sessions||{};
  const completed=Object.entries(sessions).filter(([,s])=>s.completedAt);
  const totalSets=completed.reduce((_s,[,s])=>_s+(s.sets||[]).reduce((a,ex)=>a+ex.filter(st=>st.done).length,0),0);
  const totalReps=completed.reduce((_s,[,s])=>_s+(s.sets||[]).reduce((a,ex)=>a+ex.reduce((b,st)=>b+(st.done?st.reps:0),0),0),0);
  const weekStart=getWeekStart(todayStr());
  let streak=0;
  for(let w=0;w<52;w++){
    const ws=addDays(weekStart,-w*7);
    const weekDates=Array.from({length:7},(_,i)=>addDays(ws,i));
    const weekDone=weekDates.filter(d=>sessions[d]?.completedAt).length;
    if(weekDone>0) streak++;
    else if(w===0) break;
    else break;
  }
  document.getElementById('stat-sessions').innerHTML=`${completed.length}<span class="stat-card-u">done</span>`;
  document.getElementById('stat-sets').innerHTML=`${totalSets}<span class="stat-card-u">sets</span>`;
  document.getElementById('stat-reps').innerHTML=`${totalReps}<span class="stat-card-u">reps</span>`;
  document.getElementById('stat-streak').innerHTML=`${streak}<span class="stat-card-u">weeks</span>`;
  const histEl=document.getElementById('history-list');
  if(!completed.length){ histEl.innerHTML=`<div class="empty-state">No sessions completed yet</div>`; return; }
  const sorted=completed.sort((a,b)=>b[0].localeCompare(a[0]));
  let html=`<div class="history-list">`;
  sorted.forEach(([date,session])=>{
    const wo=WORKOUTS.find(w=>w.id===session.workoutId);
    const sets=(session.sets||[]).reduce((a,ex)=>a+ex.filter(s=>s.done).length,0);
    const reps=(session.sets||[]).reduce((a,ex)=>a+ex.reduce((b,s)=>b+(s.done?s.reps:0),0),0);
    html+=`<div class="history-item"><div class="history-item-left"><div class="history-item-name">${wo?wo.name:'Workout'}</div><div class="history-item-date">${formatDate(date)}</div></div><div class="history-item-sets">${sets} sets · ${reps} reps</div></div>`;
  });
  html+=`</div>`;
  histEl.innerHTML=html;
  renderWeightTracker();
}

